:root {
    font-size: 20px;
}

#Container, #Stops {
    flex-grow: 1;
}

.row {
    flex-direction: row;
}

#Dock {
    font-size: 128px;
    padding: 30px;
    -unity-font-style: bold;
    -unity-text-align: upper-center;
}

#Station {
    font-size: 25px;
}

.departure #Container {
    background-color: #337ab8;
}

.arrival #Container {
    background-color: #1c8e1c;
}