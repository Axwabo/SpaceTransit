Button {
    width: 250px;
    height: 60px;
    margin: 10px;
    font-size: 36px;
    background-color: #1E1E1E;
    border-width: 0;
    -unity-font-definition: url("project://database/Assets/Fonts/Tektur/Tektur-Regular.ttf?fileID=12800000&guid=426ae23ecd68b31469c28954f0ab1280&type=3#Tektur-Regular");
}

Button:hover {
    background-color: #464646;
}

Button:active {
    background-color: #646464;
}